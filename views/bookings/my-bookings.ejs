<% layout("/layouts/boilerplate") %>

<div class="container mt-4 mb-5">
  <h3 class="mb-4">My Bookings</h3>

  <% if(bookings.length === 0) { %>
    <p class="text-muted">You have no bookings yet. <a href="/listings">Explore listings</a></p>
  <% } else { %>

  <div class="row">
    <% for(let booking of bookings) { %>
      <% if(booking.listing) { %>
      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <img src="<%= booking.listing.image.url %>" class="card-img-top" style="height:200px;object-fit:cover;">
          <div class="card-body">
            <h5><%= booking.listing.title %></h5>
            <p class="text-muted mb-1"><%= booking.listing.location %></p>
            <p class="mb-1"><strong>Check-in:</strong> <%= booking.checkin.toDateString() %></p>
            <p class="mb-1"><strong>Check-out:</strong> <%= booking.checkout.toDateString() %></p>
            <p class="mb-1"><strong>Nights:</strong> <%= booking.nights %></p>
            <p class="mb-2"><strong>Total:</strong> ₹<%= booking.total.toLocaleString("en-IN") %></p>
            <% if(booking.status === "cancelled") { %>
              <span class="badge bg-danger">Cancelled</span>
            <% } else { %>
              <span class="badge bg-success">Confirmed</span>
              <form method="POST" action="/bookings/<%= booking._id %>/cancel?_method=PATCH" class="d-inline">
                <button class="btn btn-sm btn-outline-danger ms-2"
                  onclick="return confirm('Cancel this booking?')">
                  Cancel
                </button>
              </form>
            <% } %>
          </div>
        </div>
      </div>
      <% } %>
    <% } %>
  </div>

  <% } %>
</div>