<% layout("/layouts/boilerplate") %>
<script>
const mapToken = "<%= mapToken %>";
const coordinates = <%- JSON.stringify(listing.geometry.coordinates) %>;
const listingTitle = "<%= listing.title %>";
</script>

<div class="container mt-4 mb-5">

  <div class="row">
    <div class="col-8 offset-2">

      <!-- LISTING TITLE -->
      <h3 class="mb-1"><%= listing.title %></h3>

      <p class="text-muted mb-4">
        Hosted by <%= listing.owner ? listing.owner.username : "Unknown Host" %>
      </p>

      <!-- LISTING CARD -->
      <div class="card shadow-sm">

        <img src="<%= listing.image.url %>" 
             class="card-img-top"
             style="height:350px; object-fit:cover;"
             alt="listing_image">

        <div class="card-body">

          <p class="card-text">
            <%= listing.description %>
          </p>

          <p class="mb-1">
            <strong>Location:</strong> <%= listing.location %>
          </p>

          <p class="mb-1">
            <strong>Country:</strong> <%= listing.country %>
          </p>

          <p class="mb-3">
            <strong>Price:</strong>
            ₹ <%= listing.price.toLocaleString("en-IN") %> / night
          </p>

        </div>

      </div>

     <hr class="mt-4">

<div class="card p-4 shadow-sm mt-3">

<h5>Book this stay</h5>

<form method="POST" action="/bookings/<%= listing._id %>" onsubmit="console.log('FORM SUBMITTED')">

<div class="row mt-3">

<div class="col-md-6">
<label>Check-in</label>
<input type="date" id="checkin" name="checkin" class="form-control" required>
</div>

<div class="col-md-6">
<label>Check-out</label>
<input type="date" id="checkout" name="checkout" class="form-control" required>
</div>

</div>

<input type="hidden" name="nights" id="nightsInput">
<input type="hidden" name="subtotal" id="subtotalInput">
<input type="hidden" name="tax" id="taxInput">
<input type="hidden" name="total" id="totalInput">

<div class="mt-3">

<p>Nights: <span id="nights">0</span></p>
<p>Subtotal: ₹<span id="subtotal">0</span></p>
<p>Taxes (18% GST): ₹<span id="tax">0</span></p>

<h5>Total: ₹<span id="total">0</span></h5>

</div>

<button type="submit" class="btn btn-dark mt-2">
  Confirm Booking
</button>

</form>

</div>

      <!-- EDIT DELETE BUTTONS -->
      <% if(currentUser && listing.owner && listing.owner._id.equals(currentUser._id)) { %>

      <div class="mt-4 d-flex gap-2">

        <a href="/listings/<%= listing._id %>/edit"
           class="btn btn-dark">
          Edit
        </a>

        <form method="POST"
              action="/listings/<%= listing._id %>?_method=DELETE">

          <button class="btn btn-danger">
            Delete
          </button>

        </form>

      </div>

      <% } %>

      <!-- REVIEW FORM -->
      <hr class="mt-5">

      <% if(currentUser){ %>

      <div class="card review-form-card p-4 shadow-sm mt-4">

        <h4 class="mb-3">Leave a Review</h4>

        <form action="/listings/<%= listing._id %>/reviews"
              method="POST"
              novalidate
              class="needs-validation">

          <!-- Rating -->
          <div class="mb-4">

            <div class="d-flex align-items-center gap-2">
              <label class="form-label fw-semibold m-0">Rating</label>

              <div class="star-rating">
                <input type="radio" name="review[rating]" value="5" id="star5" required>
                <label for="star5">★</label>

                <input type="radio" name="review[rating]" value="4" id="star4">
                <label for="star4">★</label>

                <input type="radio" name="review[rating]" value="3" id="star3">
                <label for="star3">★</label>

                <input type="radio" name="review[rating]" value="2" id="star2">
                <label for="star2">★</label>

                <input type="radio" name="review[rating]" value="1" id="star1">
                <label for="star1">★</label>
              </div>
            </div>

            <div class="invalid-feedback rating-error">
              Please select a rating.
            </div>

          </div>

          <!-- Comment -->
          <div class="mb-4">

            <label for="comment" class="form-label fw-semibold">
              Comments
            </label>

            <textarea id="comment"
                      name="review[comment]"
                      rows="4"
                      class="form-control"
                      placeholder="Share your experience..."
                      required></textarea>

            <div class="invalid-feedback">
              Please write a comment before submitting.
            </div>

          </div>

          <button class="btn btn-dark">
            Submit Review
          </button>

        </form>

      </div>

      <% } else { %>

      <p class="mt-4">
        You must <a href="/login">login</a> to leave a review.
      </p>

      <% } %>

      <!-- REVIEWS SECTION -->
      <hr class="mt-5">

      <h4 class="mb-3">All Reviews</h4>

      <div class="row">

        <% for(let review of listing.reviews) { %>

        <div class="col-md-6 mb-3">

          <div class="card review-card p-3">

            <h6 class="fw-bold mb-2">
              <% if(review.author){ %>
                <%= review.author.username %>
              <% } else { %>
                Anonymous
              <% } %>
            </h6>

            <div class="stars mb-2">

              <% for(let i=1;i<=review.rating;i++){ %>
                <span class="star">★</span>
              <% } %>

              <% for(let i=review.rating;i<5;i++){ %>
                <span class="star-empty">☆</span>
              <% } %>

            </div>

            <p class="review-comment">
              <%= review.comment %>
            </p>

            <% if(currentUser && review.author && review.author._id.equals(currentUser._id)){ %>

            <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                  method="POST"
                  class="mt-2">

              <button class="btn btn-sm btn-outline-danger">
                Delete
              </button>

            </form>

            <% } %>

          </div>

        </div>

        <% } %>

      </div>

    </div>
  </div>
</div>
  <!-- MAP SECTION -->
  <div class="row mt-5">
  <div class="col-6 offset-3">
    <h3>Where you'll stay</h3>
    <div id="map" style="height:400px;"></div>
  </div>
</div>

</div>

<script>
(() => {
  const forms = document.querySelectorAll('.needs-validation');

  forms.forEach(form => {
    form.addEventListener('submit', e => {

      const rating = form.querySelector('input[name="review[rating]"]:checked');
      const error = form.querySelector('.rating-error');

      if (!rating) {
        e.preventDefault();
        error.style.display = "block";
      } else {
        error.style.display = "none";
      }

      if (!form.checkValidity()) {
        e.preventDefault();
      }

      form.classList.add('was-validated');
    });
  });
})();
</script>

<script src="/js/map.js"></script>

<script>

const price = <%= listing.price %>;

const checkin = document.getElementById("checkin");
const checkout = document.getElementById("checkout");

checkin.addEventListener("change",calculate);
checkout.addEventListener("change",calculate);

function calculate(){

const start = new Date(checkin.value);
const end = new Date(checkout.value);

if(!checkin.value || !checkout.value) return;

const nights = (end-start)/(1000*60*60*24);

if(nights<=0) return;

const subtotal = nights * price;
const tax = subtotal * 0.18;
const total = subtotal + tax;

document.getElementById("nights").innerText = nights;
document.getElementById("subtotal").innerText = subtotal.toFixed(0);
document.getElementById("tax").innerText = tax.toFixed(0);
document.getElementById("total").innerText = total.toFixed(0);

document.getElementById("nightsInput").value = nights;
document.getElementById("subtotalInput").value = subtotal;
document.getElementById("taxInput").value = tax;
document.getElementById("totalInput").value = total;

}

</script>

