<% layout('layouts/boilerplate') %>

<div class="container mt-4 mb-5">
  <div class="row">
    <div class="col-8 offset-2">

      <h3 class="mb-4">Create a New Listing</h3>

      <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">

        <!-- Title -->
        <div class="mb-3">
          <label class="form-label">Title</label>
          <input 
            name="listing[title]" 
            type="text" 
            class="form-control" 
            placeholder="Enter title"
            required>
          <div class="valid-feedback">Title looks good!</div>
        </div>

        <!-- Description -->
        <div class="mb-3">
          <label class="form-label">Description</label>
          <textarea 
            name="listing[description]" 
            class="form-control"
            rows="3"
            placeholder="Enter description"
            required></textarea>
          <div class="invalid-feedback">Description is required!</div>
        </div>

        <!-- Image -->
        <div class="mb-3">
          <label class="form-label">Upload Image</label>
          <input 
            name="listing[image]" 
            type="file" 
            class="form-control">
        </div>

        <!-- Location -->
        <div class="mb-3">
          <label class="form-label">Location</label>
          <input 
            name="listing[location]" 
            type="text" 
            class="form-control"
            placeholder="Enter location"
            required>
          <div class="invalid-feedback">Location is required!</div>
        </div>

        <!-- Country + Price -->
        <div class="row">

          <div class="col-md-6 mb-3">
            <label class="form-label">Country</label>
            <input 
              name="listing[country]" 
              type="text" 
              class="form-control"
              placeholder="Enter country"
              required>
          </div>

          <div class="col-md-6 mb-3">
            <label class="form-label">Price (₹ per night)</label>
            <input 
              name="listing[price]" 
              type="number" 
              class="form-control"
              placeholder="Enter price"
              required>
          </div>

        </div>

        <!-- Trending -->
  <div class="mb-3">

<label class="form-label">Category</label>

<div class="form-check">
<input class="form-check-input" type="checkbox" name="listing[category][]" value="farms">
<label class="form-check-label">Farms</label>
</div>

<div class="form-check">
<input class="form-check-input" type="checkbox" name="listing[category][]" value="cabins">
<label class="form-check-label">Cabins</label>
</div>

<div class="form-check">
<input class="form-check-input" type="checkbox" name="listing[category][]" value="views">
<label class="form-check-label">Amazing Views</label>
</div>

<div class="form-check">
<input class="form-check-input" type="checkbox" name="listing[category][]" value="beach">
<label class="form-check-label">Beach</label>
</div>

<div class="form-check">
<input class="form-check-input" type="checkbox" name="listing[category][]" value="pools">
<label class="form-check-label">Pools</label>
</div>

</div>
<div class="form-check mt-3">

<input
class="form-check-input"
type="checkbox"
name="listing[trending]"
value="true"
id="trendingCheck">

<label class="form-check-label" for="trendingCheck">
🔥 Mark as Trending
</label>

</div>

        <button class="btn btn-dark add-btn">
          Add Listing
        </button>

      </form>

    </div>
  </div>
</div>
