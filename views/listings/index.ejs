<% layout("/layouts/boilerplate") %>
<div class="filters">

<a href="/listings?trending=true" class="filter">
<i class="fa-solid fa-fire"></i>
<p>Trending</p>
</a>

<a href="/listings?category=farms" class="filter">
<i class="fa-solid fa-tractor"></i>
<p>Farms</p>
</a>

<a href="/listings?category=cabins" class="filter">
<i class="fa-solid fa-house-chimney"></i>
<p>Cabins</p>
</a>

<a href="/listings?category=views" class="filter">
<i class="fa-solid fa-mountain"></i>
<p>Amazing Views</p>
</a>

<a href="/listings?category=beach" class="filter">
<i class="fa-solid fa-umbrella-beach"></i>
<p>Beach</p>
</a>

<a href="/listings?category=pools" class="filter">
<i class="fa-solid fa-water-ladder"></i>
<p>Pools</p>
</a>

<a href="/listings" class="filter">
<i class="fa-solid fa-border-all"></i>
<p>All</p>
</a>

</div>


<div class="container mt-4">
    <!-- <h3 class="mb-4">All Listings</h3> -->

    <div class="row">

        <% listings.forEach(listing => { %>

            <div class="col-lg-4 col-md-6 col-sm-12 mb-4">

                <div class="card h-100 shadow-sm listing-card">

                    <img src="<%= listing.image.url %>"
                         class="card-img-top"
                         style="height: 250px; object-fit: cover;"
                         alt="listing_image">

                    <div class="card-body">
                        <h5 class="card-title">
                            <%= listing.title %>
                        </h5>

                        <p class="card-text">
                            ₹ <%= listing.price %> / night
                        </p>

                        <a href="/listings/<%= listing._id %>" 
                           class="btn btn-dark">
                           View Details
                        </a>
                    </div>

                </div>

            </div>

        <% }) %>

    </div>
</div>


